# OpenClaw 量化交易 Agent — 環境變數配置範例
# Copy this file to .env and fill in your actual values.
# 複製此文件為 .env，並填入您的真實密鑰。
# NEVER commit your .env file to version control!

# ──────────────────────────────────────────────
# AI 模型設定 / AI Model Settings
# ──────────────────────────────────────────────

# AI 模型 API Key（OpenAI 或 Anthropic）
# Your OpenAI or Anthropic API key
OPENCLAW_API_KEY=your_openai_or_anthropic_api_key_here

# 使用的模型名稱 / Model to use
# Examples: gpt-4o, gpt-4o-mini, claude-sonnet-4-20250514
OPENCLAW_MODEL=gpt-4o

# ──────────────────────────────────────────────
# 交易所設定 / Exchange Settings
# ──────────────────────────────────────────────

# 交易所 API Key
EXCHANGE_API_KEY=your_exchange_api_key_here

# 交易所 API Secret
EXCHANGE_API_SECRET=your_exchange_api_secret_here

# 交易所名稱 / Exchange name
# Supported: binance, okx, bybit, coinbase
EXCHANGE_NAME=binance

# ──────────────────────────────────────────────
# 交易設定 / Trading Settings
# ──────────────────────────────────────────────

# 交易模式 / Trading mode
# paper = 模擬交易（推薦初始使用）/ paper trading (recommended for initial use)
# live  = 實盤交易（謹慎使用）/ live trading (use with caution)
TRADING_MODE=paper

# 單筆交易最大風險百分比 / Max risk per trade as percentage of portfolio
RISK_LIMIT_PCT=2.0

# 單一持倉最大規模（以 USDT 計）/ Max position size in USDT
MAX_POSITION_SIZE=1000

# ──────────────────────────────────────────────
# 系統設定 / System Settings
# ──────────────────────────────────────────────

# 心跳檢查間隔（秒）/ Heartbeat interval in seconds
HEARTBEAT_INTERVAL=60

# 日誌級別 / Log level
# Options: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
